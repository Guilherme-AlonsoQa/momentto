PORT=3000
NETLIFY_TOKEN=
NETLIFY_SITE_ID=
NETLIFY_ACCOUNT_SLUG=
NETLIFY_ORDER_DEPLOY_MODE=create_site
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
# E-mail que recebe notificação a cada novo pedido (opcional, padrão = SMTP_USER)
ADMIN_EMAIL=

# Mercado Pago — Access Token de TESTE (começa com TEST-)
# Encontre em: Mercado Pago > Seu negócio > Configurações > Credenciais > Credenciais de teste
MP_ACCESS_TOKEN=
# URL do webhook (opcional — preenchida automaticamente em produção)
# Ex.: https://seu-site.netlify.app/api/pix/webhook
MP_WEBHOOK_URL=
